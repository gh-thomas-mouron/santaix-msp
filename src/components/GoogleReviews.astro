---
// Client-side component to fetch Google reviews live
// This requires a Google Places API key configured on the client side
// For a simpler solution, use build-time values in Footer.astro

interface Props {
  placeId?: string;
  apiKey?: string;
  googleMapsUrl: string;
}

const { placeId, apiKey, googleMapsUrl } = Astro.props;
---

<div id="google-reviews-container" class="mt-4 pt-4 border-t border-blue-800">
  <a 
    href={googleMapsUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="flex items-center gap-2 text-blue-100 hover:text-white transition-colors no-underline group"
  >
    <div class="flex items-center gap-1">
      <div class="flex items-center" id="stars-container">
        <!-- Stars will be rendered here -->
      </div>
      <span class="text-sm font-medium ml-1" id="rating-text">-</span>
    </div>
    <span class="text-xs text-blue-200 group-hover:text-blue-100" id="reviews-count"></span>
    <svg class="w-4 h-4 ml-1 opacity-70 group-hover:opacity-100" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
    </svg>
  </a>
</div>

{placeId && apiKey && (
  <script>
    // Fetch Google Place rating client-side
    async function fetchGoogleRating() {
      try {
        const response = await fetch(
          `https://maps.googleapis.com/maps/api/place/details/json?place_id=${placeId}&fields=rating,user_ratings_total&key=${apiKey}`
        );
        const data = await response.json();
        
        if (data.status === 'OK' && data.result) {
          const rating = data.result.rating || 0;
          const count = data.result.user_ratings_total || 0;
          
          // Render stars
          const starsContainer = document.getElementById('stars-container');
          const ratingText = document.getElementById('rating-text');
          const reviewsCount = document.getElementById('reviews-count');
          
          if (starsContainer && ratingText && reviewsCount && rating > 0) {
            starsContainer.innerHTML = '';
            for (let i = 1; i <= 5; i++) {
              const star = document.createElement('svg');
              star.className = `w-4 h-4 ${i <= Math.round(rating) ? 'text-yellow-400 fill-current' : 'text-gray-400 fill-current'}`;
              star.setAttribute('viewBox', '0 0 24 24');
              star.innerHTML = '<path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />';
              starsContainer.appendChild(star);
            }
            
            ratingText.textContent = rating.toFixed(1);
            if (count > 0) {
              reviewsCount.textContent = `(${count} avis)`;
            }
          }
        }
      } catch (error) {
        console.error('Error fetching Google rating:', error);
        // Hide container on error
        const container = document.getElementById('google-reviews-container');
        if (container) container.style.display = 'none';
      }
    }
    
    fetchGoogleRating();
  </script>
)}

