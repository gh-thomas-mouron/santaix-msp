---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
---

<Layout
  title="Accueil"
  description="SANTAIX Maison de Santé à Aix-en-Provence : médecin généraliste, échographie et urgences de proximité. Prenez RDV en ligne."
>
  <Header />
  
  <main class="flex-grow">
    <!-- Hero Section -->
    <section class="relative bg-gradient-to-br from-blue-50 via-teal-50 to-blue-100 py-12 md:py-24 lg:py-32 overflow-hidden">
      <div class="max-w-7xl mx-auto px-4">
        <div class="max-w-4xl mx-auto text-center">
          <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold text-blue-900 mb-4 md:mb-6 leading-tight px-2">
            Centre de Santé & Échographie à Aix-en-Provence
          </h1>
          <p class="text-base sm:text-lg md:text-xl lg:text-2xl text-gray-700 mb-6 md:mb-8 px-2">
            <span class="text-teal-600 font-semibold">SANTAIX</span> — Votre maison de santé au cœur d'Aix-en-Provence
          </p>
          <div class="flex flex-col sm:flex-row gap-3 sm:gap-4 justify-center px-4">
            <a
              href={baseUrl + "equipe"}
              title="Découvrir notre équipe médicale - SANTAIX"
              class="px-6 py-3 sm:px-8 sm:py-4 bg-blue-600 text-white rounded-lg font-semibold hover:bg-blue-700 transition-all duration-200 shadow-lg hover:shadow-xl text-base sm:text-lg no-underline"
            >
              Découvrir notre équipe
            </a>
            <a
              href="https://www.doctolib.fr/centre-de-sante/aix-en-provence/santaix"
              target="_blank"
              rel="noopener noreferrer"
              class="px-6 py-3 sm:px-8 sm:py-4 bg-teal-500 text-white rounded-lg font-semibold hover:bg-teal-600 transition-all duration-200 shadow-lg hover:shadow-xl text-base sm:text-lg no-underline"
            >
              Prendre rendez-vous
            </a>
          </div>
        </div>
      </div>
      
      <!-- Décoration -->
      <div class="absolute top-0 left-0 w-full h-full opacity-10 pointer-events-none">
        <div class="absolute top-10 right-10 w-64 h-64 bg-teal-400 rounded-full blur-3xl"></div>
        <div class="absolute bottom-10 left-10 w-96 h-96 bg-blue-400 rounded-full blur-3xl"></div>
      </div>
    </section>

    <!-- Services Section -->
    <section class="py-12 md:py-16 bg-white">
      <div class="max-w-7xl mx-auto px-4">
        <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-center text-blue-900 mb-8 md:mb-12 px-2">
          Médecine Générale, Échographie et Urgences de proximité
        </h2>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8 max-w-6xl mx-auto">
          <!-- Service 1 -->
          <div class="bg-gradient-to-br from-blue-50 to-teal-50 rounded-xl p-8 hover:shadow-lg transition-shadow">
            <div class="text-4xl mb-4">👨‍⚕️</div>
            <h3 class="text-xl font-bold text-blue-900 mb-3">Médecine Générale</h3>
            <p class="text-gray-700">
              Accueil et suivi des patients de l'enfance à l'âge adulte. Médecin traitant.
            </p>
          </div>

          <!-- Service 2 -->
          <div class="bg-gradient-to-br from-blue-50 to-teal-50 rounded-xl p-8 hover:shadow-lg transition-shadow">
            <div class="text-4xl mb-4">🔬</div>
            <h3 class="text-xl font-bold text-blue-900 mb-3">Échographie médicale</h3>
            <p class="text-gray-700">
              Examens échographiques réalisés par des médecins spécialisés.
            </p>
          </div>

          <!-- Service 3 -->
          <div class="bg-gradient-to-br from-blue-50 to-teal-50 rounded-xl p-8 hover:shadow-lg transition-shadow">
            <div class="text-4xl mb-4">🩺</div>
            <h3 class="text-xl font-bold text-blue-900 mb-3">Urgences de proximité</h3>
            <p class="text-gray-700">
              Traumatologie, sutures, contentions, soins et pansements de plaie.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Welcome Section with Photos -->
    <section class="py-12 md:py-16 bg-gradient-to-br from-gray-50 to-blue-50">
      <div class="max-w-7xl mx-auto px-4">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 md:gap-12 items-center">
          <!-- Photo salle d'attente -->
          <div class="order-2 lg:order-1 flex justify-center lg:justify-start">
            <div class="rounded-2xl shadow-xl overflow-hidden aspect-square max-w-md w-full">
              <img 
                src={`${baseUrl}galerie/salle-attente-square.jpg`}
                alt="Salle d'attente du Centre de Santé SANTAIX à Aix-en-Provence"
                class="w-full h-full object-cover"
                loading="lazy"
              />
            </div>
          </div>
          
          <!-- Texte -->
          <div class="order-1 lg:order-2">
            <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-blue-900 mb-4 md:mb-6 text-center md:text-left">
              Un accueil chaleureux et professionnel
            </h2>
            <p class="text-base sm:text-lg text-gray-700 mb-4 leading-relaxed">
              Au Centre de Santé SANTAIX, nous mettons tout en œuvre pour vous offrir un environnement accueillant et rassurant. Notre équipe est à votre écoute pour vous accompagner dans vos démarches de santé.
            </p>
            <p class="text-base sm:text-lg text-gray-700 leading-relaxed">
              Des locaux modernes, fraîchement rénovés et bien équipés vous attendent pour votre confort et votre bien-être.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section id="rendez-vous" class="py-12 md:py-16 bg-gradient-to-r from-blue-600 to-teal-500">
      <div class="max-w-7xl mx-auto px-4 text-center">
        <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-white mb-4 md:mb-6 px-2">
          Prêt à prendre rendez-vous ?
        </h2>
        <p class="text-base sm:text-lg md:text-xl text-blue-50 mb-6 md:mb-8 max-w-2xl mx-auto px-4">
          Consultez la liste de nos praticiens et prenez rendez-vous en ligne
        </p>
        <a
          href="https://www.doctolib.fr/centre-de-sante/aix-en-provence/santaix"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block px-6 py-3 sm:px-8 sm:py-4 bg-white text-blue-600 rounded-lg font-semibold hover:bg-gray-50 transition-all duration-200 shadow-lg hover:shadow-xl text-base sm:text-lg no-underline"
        >
          Voir tous les praticiens
        </a>
      </div>
    </section>

    <!-- Info Section with Photo -->
    <section class="py-12 md:py-16 bg-white">
      <div class="max-w-7xl mx-auto px-4">
        <div class="max-w-6xl mx-auto">
          <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-center text-blue-900 mb-8 md:mb-12 px-2">
            Informations pratiques
          </h2>
          
          <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 md:gap-8">
            <!-- Photo extérieure -->
            <div class="lg:col-span-1">
              <div class="rounded-xl shadow-lg overflow-hidden h-full">
                <img 
                  src={`${baseUrl}galerie/exterieur.jpg`}
                  alt="Façade du cabinet médical SANTAIX, 195 Bd Ferdinand de Lesseps, Aix-en-Provence"
                  class="w-full h-full object-cover"
                  loading="lazy"
                />
              </div>
            </div>
            
            <!-- Informations -->
            <div class="lg:col-span-2 grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
              <div class="bg-gradient-to-br from-blue-50 to-teal-50 rounded-xl p-5 md:p-6 shadow-md">
                <h3 class="text-lg sm:text-xl font-bold text-blue-900 mb-3 md:mb-4">Cabinet médical Lesseps</h3>
                <p class="text-gray-700 mb-2">195 Boulevard Ferdinand de Lesseps</p>
                <p class="text-gray-700 mb-4">13090 Aix-en-Provence</p>
                <a href={baseUrl + "acces"} title="Plan d'accès au cabinet médical SANTAIX à Aix-en-Provence" class="text-teal-600 hover:text-teal-700 font-medium">
                  → Voir le plan d'accès
                </a>
              </div>

              <div class="bg-gradient-to-br from-blue-50 to-teal-50 rounded-xl p-5 md:p-6 shadow-md">
                <h3 class="text-lg sm:text-xl font-bold text-blue-900 mb-3 md:mb-4">📅 Prendre RDV</h3>
                <p class="text-gray-700 mb-4">
                  Prenez rendez-vous en ligne facilement sur Doctolib
                </p>
                <a href="https://www.doctolib.fr/centre-de-sante/aix-en-provence/santaix" target="_blank" rel="noopener noreferrer" class="inline-block px-4 py-2 bg-teal-500 text-white rounded-lg hover:bg-teal-600 transition-colors font-medium no-underline">
                  Réserver en ligne
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
