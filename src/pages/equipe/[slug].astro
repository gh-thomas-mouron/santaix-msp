---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import practitionersJson from '../../data/practitioners.json';

const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';

export async function getStaticPaths() {
  // Load data directly inside getStaticPaths - handle both array and default export
  const allPractitioners = Array.isArray(practitionersJson) 
    ? practitionersJson 
    : (practitionersJson as any).default || [];
  
  const slugs = allPractitioners.map((p: any) => p.slug);
  return slugs.map((slug: string) => ({
    params: { slug },
  }));
}

const { slug } = Astro.params;
// Load practitioners data for component rendering
const allPractitionersData = Array.isArray(practitionersJson) 
  ? practitionersJson 
  : (practitionersJson as any).default || [];
const practitioner = allPractitionersData.find((p: any) => p.slug === slug);

if (!practitioner) {
  return Astro.redirect(baseUrl + 'equipe');
}

// Determine image URL - handle local paths
let imageUrl = practitioner.pictureUrl;
if (imageUrl && !imageUrl.startsWith('http') && !imageUrl.startsWith('/')) {
  // Local file path - make it relative to public folder
  imageUrl = baseUrl + imageUrl.replace(/^public\//, '');
} else if (imageUrl && imageUrl.startsWith('/')) {
  imageUrl = baseUrl + imageUrl.slice(1);
}
---

<Layout 
  title={`${practitioner.name} - ${practitioner.specialty}`}
  description={`${practitioner.name}, ${practitioner.specialty} au Centre de Santé SANTAIX à Aix-en-Provence`}
>
  <Header />
  
  <main class="flex-grow">
    <!-- Hero Section -->
    <section class="bg-gradient-to-br from-blue-600 to-teal-500 py-12 md:py-20 lg:py-24">
      <div class="max-w-7xl mx-auto px-4">
        <div class="max-w-4xl mx-auto text-center text-white">
          <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-4 md:mb-6 px-2">{practitioner.name}</h1>
          <p class="text-base sm:text-lg md:text-xl lg:text-2xl text-blue-50 px-2">
            {practitioner.specialty}
          </p>
        </div>
      </div>
    </section>

    <!-- Doctor Details -->
    <section class="py-12 md:py-16 bg-gray-50">
      <div class="max-w-4xl mx-auto px-4">
        <div class="bg-white rounded-xl shadow-md p-8 md:p-12">
          {imageUrl ? (
            <div class="flex justify-center mb-8">
              <img 
                src={imageUrl}
                alt={`${practitioner.name}, ${practitioner.specialty} - Centre SANTAIX Aix-en-Provence`}
                class="w-48 h-48 rounded-full object-cover border-4 border-blue-100"
                onerror="this.style.display='none'"
              />
            </div>
          ) : null}
          
          <div class={`text-center ${imageUrl ? 'mb-8' : 'mb-0'}`}>
            <h2 class="text-2xl md:text-3xl font-bold text-blue-900 mb-2">{practitioner.name}</h2>
            <p class="text-lg md:text-xl text-teal-600 font-medium">{practitioner.specialty}</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Tabs Navigation -->
    {allPractitionersData.length > 1 && (
      <section class="py-8 bg-white border-t border-gray-200">
        <div class="max-w-7xl mx-auto px-4">
          <div class="flex flex-wrap justify-center gap-2 md:gap-4">
            {allPractitionersData.map((p) => (
              <a
                href={baseUrl + `equipe/${p.slug}`}
                title={`${p.name}, ${p.specialty} - SANTAIX`}
                class={`px-4 py-2 rounded-lg font-medium transition-colors no-underline ${
                  p.slug === slug
                    ? 'bg-blue-600 text-white'
                    : 'bg-gray-100 text-gray-700 hover:bg-gray-200'
                }`}
              >
                {p.name.replace(/^Dr\.?\s*/i, '')}
              </a>
            ))}
            <a
              href={baseUrl + 'equipe'}
              title="Voir toute l'équipe médicale SANTAIX"
              class={`px-4 py-2 rounded-lg font-medium transition-colors no-underline ${
                slug === undefined
                  ? 'bg-blue-600 text-white'
                  : 'bg-gray-100 text-gray-700 hover:bg-gray-200'
              }`}
            >
              Tous
            </a>
          </div>
        </div>
      </section>
    )}

    <!-- Info Box -->
    <section class="py-10 md:py-12 bg-white">
      <div class="max-w-7xl mx-auto px-4">
        <div class="max-w-3xl mx-auto bg-blue-50 rounded-xl p-5 md:p-8 border border-blue-100">
          <h2 class="text-xl sm:text-2xl font-bold text-blue-900 mb-3 md:mb-4">
            💡 Informations pratiques
          </h2>
          <div class="space-y-3 text-gray-700">
            <p>
              ✓ <strong>Établissement conventionné</strong> - Carte Vitale acceptée
            </p>
            <p>
              ✓ <strong>Tiers payant</strong> : Sécurité sociale
            </p>
            <p>
              ✓ <strong>Moyens de paiement</strong> : Chèques, espèces, carte bancaire et virement
            </p>
            <p>
              ✓ <strong>Langues parlées</strong> : Français, Anglais, Arabe
            </p>
          </div>
          <div class="mt-6 pt-6 border-t border-blue-200">
            <a href="https://www.doctolib.fr/centre-de-sante/aix-en-provence/santaix" target="_blank" rel="noopener noreferrer" class="inline-block px-6 py-3 bg-teal-500 text-white rounded-lg font-semibold hover:bg-teal-600 transition-colors no-underline">
              Prendre rendez-vous sur Doctolib
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
